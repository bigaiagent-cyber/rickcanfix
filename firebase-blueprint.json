{
  "entities": {
    "ProjectInquiry": {
      "title": "Project Inquiry",
      "description": "Form submission from a potential customer",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "message": { "type": "string", "description": "Project details" },
        "fileCount": { "type": "integer", "description": "Number of attached files" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["name", "email", "phone", "message"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "ProjectInquiry",
      "description": "Collection of project inquiries"
    }
  }
}
