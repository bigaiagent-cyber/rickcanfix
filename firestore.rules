rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper
    function isValidInquiry(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.message is string && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiry(request.resource.data);
      allow get, list, update, delete: if false; // Only manageable via console
    }
  }
}
